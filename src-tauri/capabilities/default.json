{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-exists",
    "dialog:default",
    "dialog:allow-open",
    "http:default",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "https://cdn.projectgorgon.com/**"
        }
      ]
    }
  ]
}
